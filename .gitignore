# macOS
.DS_Store
.AppleDouble
.LSOverride
._*

# Hammerspoon runtime artifacts (archived prototype)
prototypes/hammerspoon/logs/
*.log

# Editor junk
.vscode/
.idea/
*.swp
*.swo
*~

# Claude Code per-machine state
.claude/settings.local.json
.claude/worktrees/

# Swift Package Manager — ignore build/IDE artifacts but commit
# Package.resolved so `swift test` pins the same dep versions across
# checkouts.
.build/
.swiftpm/

# Distribution output — produced by scripts/make-app.sh; never commit.
dist/

# Local-only dev tooling (private build helpers, cert config, etc).
# Each developer maintains their own dev/ as the working tree of a
# separate private repo. See dev/README.md for setup.
dev/

# Provisioning profiles. Team-specific, regenerable from
# developer.apple.com, and contain the team ID + cert hashes —
# never commit. Each developer drops their own at this path.
Resources/*.provisionprofile

# Signing certs — installed in the Keychain, not the repo.
# .cer is the public cert (not sensitive) but still doesn't belong
# in source control; .p12 carries the private key and *must* never
# be committed.
*.cer
*.p12
